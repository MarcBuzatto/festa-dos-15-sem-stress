# =============================================
# CONFIGURAÇÕES DO BACKEND — FESTA DOS 15
# Copie este arquivo para .env e preencha
# =============================================

# --- MERCADO PAGO ---
MP_ACCESS_TOKEN=APP_USR-XXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXX
MP_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
# Gerados em: https://www.mercadopago.com.br/settings/account/credentials

# --- E-MAIL (para enviar o kit após compra) ---
# Opção Gmail: ative "Senhas de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seuemail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=Kit Festa dos 15 Sem Stress <seuemail@gmail.com>

# --- LINKS DOS ARQUIVOS DO KIT ---
# Cole os links de compartilhamento dos seus arquivos
# (Google Drive, Dropbox, OneDrive — link de download direto)
LINK_GUIA=https://drive.google.com/uc?export=download&id=SEU_ID_AQUI
LINK_CHECKLIST=https://drive.google.com/uc?export=download&id=SEU_ID_AQUI
LINK_PLANILHA=https://drive.google.com/uc?export=download&id=SEU_ID_AQUI
LINK_BONUS_CRONOGRAMA=https://drive.google.com/uc?export=download&id=SEU_ID_AQUI
LINK_BONUS_PERGUNTAS=https://drive.google.com/uc?export=download&id=SEU_ID_AQUI

# --- CONFIGURAÇÕES GERAIS ---
PORT=3000
FRONTEND_URL=https://seudominio.com.br
# Chave secreta para webhook do Mercado Pago (qualquer string aleatória)
WEBHOOK_SECRET=minha-chave-secreta-123

# --- NOTIFICAÇÃO (receber e-mail de cada venda) ---
ADMIN_EMAIL=seuemail@gmail.com
